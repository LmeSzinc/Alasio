{
  "card-Alas-Game": {
    "_info": {"group": "Game", "arg": "_info", "card": "card-Alas-Game"},
    "Game": {
      "PackageName": {
        "task": "Alas",
        "group": "Game",
        "arg": "PackageName",
        "dt": "select",
        "value": "auto",
        "option": ["auto"]
      },
      "ServerName": {
        "task": "Alas",
        "group": "Game",
        "arg": "ServerName",
        "dt": "select",
        "value": "disabled",
        "option": ["disabled"]
      }
    }
  },
  "card-Alas-Emulator": {
    "_info": {"group": "Emulator", "arg": "_info", "card": "card-Alas-Emulator"},
    "Emulator": {
      "Serial": {
        "task": "Device",
        "group": "Emulator",
        "arg": "Serial",
        "dt": "input",
        "value": "auto"
      },
      "ScreenshotMethod": {
        "task": "Device",
        "group": "Emulator",
        "arg": "ScreenshotMethod",
        "dt": "select",
        "value": "auto",
        "option": ["auto", "ADB", "ADB_nc", "uiautomator2", "aScreenCap", "aScreenCap_nc", "DroidCast", "DroidCast_raw", "nemu_ipc", "ldopengl"]
      },
      "ControlMethod": {
        "task": "Device",
        "group": "Emulator",
        "arg": "ControlMethod",
        "dt": "select",
        "value": "MaaTouch",
        "option": ["ADB", "uiautomator2", "minitouch", "Hermit", "MaaTouch"]
      },
      "ScreenshotDedithering": {
        "task": "Device",
        "group": "Emulator",
        "arg": "ScreenshotDedithering",
        "dt": "checkbox",
        "value": false
      },
      "AdbRestart": {
        "task": "Device",
        "group": "Emulator",
        "arg": "AdbRestart",
        "dt": "checkbox",
        "value": false
      }
    }
  },
  "card-Alas-EmulatorInfo": {
    "_info": {"group": "EmulatorInfo", "arg": "_info", "card": "card-Alas-EmulatorInfo"},
    "EmulatorInfo": {
      "Emulator": {
        "task": "Device",
        "group": "EmulatorInfo",
        "arg": "Emulator",
        "dt": "select",
        "value": "auto",
        "option": ["auto", "NoxPlayer", "NoxPlayer64", "BlueStacks4", "BlueStacks5", "BlueStacks4HyperV", "BlueStacks5HyperV", "LDPlayer3", "LDPlayer4", "LDPlayer9", "MuMuPlayer", "MuMuPlayerX", "MuMuPlayer12", "MEmuPlayer"]
      },
      "Name": {
        "task": "Device",
        "group": "EmulatorInfo",
        "arg": "Name",
        "dt": "textarea",
        "value": "",
        "layout": "vert"
      },
      "Path": {
        "task": "Device",
        "group": "EmulatorInfo",
        "arg": "Path",
        "dt": "textarea",
        "value": "",
        "layout": "vert"
      }
    }
  },
  "card-Alas-Error": {
    "_info": {"group": "Error", "arg": "_info", "card": "card-Alas-Error"},
    "Error": {
      "HandleError": {
        "task": "Device",
        "group": "Error",
        "arg": "HandleError",
        "dt": "checkbox",
        "value": true
      },
      "SaveError": {
        "task": "Device",
        "group": "Error",
        "arg": "SaveError",
        "dt": "checkbox",
        "value": true
      },
      "OnePushConfig": {
        "task": "Device",
        "group": "Error",
        "arg": "OnePushConfig",
        "dt": "textarea",
        "value": "provider: null",
        "layout": "vert"
      },
      "ScreenshotLength": {
        "task": "Device",
        "group": "Error",
        "arg": "ScreenshotLength",
        "dt": "input-int",
        "value": 1
      }
    }
  },
  "card-Alas-Optimization": {
    "_info": {"group": "Optimization", "arg": "_info", "card": "card-Alas-Optimization"},
    "Optimization": {
      "ScreenshotInterval": {
        "task": "Device",
        "group": "Optimization",
        "arg": "ScreenshotInterval",
        "dt": "input-float",
        "value": 0.3
      },
      "CombatScreenshotInterval": {
        "task": "Device",
        "group": "Optimization",
        "arg": "CombatScreenshotInterval",
        "dt": "input-float",
        "value": 1.0
      },
      "TaskHoardingDuration": {
        "task": "Device",
        "group": "Optimization",
        "arg": "TaskHoardingDuration",
        "dt": "input-int",
        "value": 0
      },
      "WhenTaskQueueEmpty": {
        "task": "Device",
        "group": "Optimization",
        "arg": "WhenTaskQueueEmpty",
        "dt": "select",
        "value": "goto_main",
        "option": ["stay_there", "goto_main", "stop_game"]
      }
    }
  },
  "card-RestartDeviceDisplay-RestartDevice": {
    "_info": {"group": "RestartDevice", "arg": "_info", "card": "card-RestartDeviceDisplay-RestartDevice"},
    "Scheduler": {
      "Enable": {
        "task": "RestartDevice",
        "group": "Scheduler",
        "arg": "Enable",
        "cls": "SchedulerStatic",
        "i18ngroup": "SchedulerStatic",
        "dt": "static",
        "value": "enabled",
        "option": ["enabled"]
      },
      "NextRun": {
        "task": "RestartDevice",
        "group": "Scheduler",
        "arg": "NextRun",
        "cls": "SchedulerStatic",
        "dt": "datetime",
        "value": "2020-01-01T00:00:00Z"
      }
    }
  },
  "card-RestartGameDisplay-RestartGame": {
    "_info": {"group": "RestartGame", "arg": "_info", "card": "card-RestartGameDisplay-RestartGame"},
    "Scheduler": {
      "Enable": {
        "task": "RestartGame",
        "group": "Scheduler",
        "arg": "Enable",
        "cls": "SchedulerStatic",
        "i18ngroup": "SchedulerStatic",
        "dt": "static",
        "value": "enabled",
        "option": ["enabled"]
      },
      "NextRun": {
        "task": "RestartGame",
        "group": "Scheduler",
        "arg": "NextRun",
        "cls": "SchedulerStatic",
        "dt": "datetime",
        "value": "2020-01-01T00:00:00Z"
      }
    }
  }
}